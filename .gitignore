# ============================================================================
# DisSysLab specific
# ============================================================================
# Student work
student_work/
my_projects/

# Scratch dirs created when running recipe examples (e.g.
# `dsl init org_news_filter my_filter`).
my_filter/
my_feed/
my_office/
my_stocks/
my_briefing/

for_instructors/

# Example outputs
examples/**/output/
examples/**/results/

# Office runtime output. Gallery offices write JSONL via jsonl_recorder
# sinks; this output should never be committed even if a developer runs
# `dsl run` from inside the source tree.
dissyslab/gallery/**/*.jsonl
# ...except problems.jsonl in the debate office. That file is fixture
# *input*, not runtime output — the gate role reads it at construction
# time, so it must ship with the package or the office fails to import
# (and the test_compiles[debate] test fails in CI).
!dissyslab/gallery/apps/debate/problems.jsonl

# periodic_brief and similar offices write a markdown artifact to the
# directory dsl was run from. If that happens to be the source tree,
# don't commit it.
/brief.md
/morning_brief.md
/your_brief.md

# When `dsl run` is invoked from the repo root (typical during
# development), gallery offices write their outputs there rather
# than inside dissyslab/gallery/. The /*.jsonl glob is anchored to
# the repo root, so it does NOT match tests/fixtures/*.jsonl or
# any other nested JSONL we legitimately ship.
/*.jsonl

# periodic_brief now also produces a styled HTML brief, and
# competitor_watch writes a markdown digest of the day.
/brief.html
/competitors.md

# gmail_sink in preview mode (default when GMAIL_APP_PASSWORD is
# unset) appends would-be emails here in the cwd. Don't commit
# users' job-match previews if dsl is run from the source tree.
/outbox.md
dissyslab/gallery/**/outbox.md

# job_hunter's job_html_sink writes a live HTML report. Same rule
# as brief.html — never commit a user's run output.
/matched_jobs.html
dissyslab/gallery/**/matched_jobs.html

# `dsl build` generated runtime code per office. Always regenerable;
# never commit.
dissyslab/gallery/**/build/

# wardrobe_assistant runtime state — tracks which items are clean
# vs worn vs in-laundry. Mutates on every run; commits would record
# personal wear history we don't want in the repo. wardrobe_outfits
# is the per-run jsonl recorder output; same rule.
/wardrobe_state.json
/wardrobe_outfits.jsonl
dissyslab/gallery/**/wardrobe_state.json
dissyslab/gallery/**/wardrobe_outfits.jsonl

# Personal scratch in examples/. Add specific names as Mani / Kamala
# accumulate throwaway smoke-test scripts.
examples/try.py

# Logs
logs/
dev/
!dev/experiments/specialist_agents/

# Internal planning docs (not for public repo)
ACTION_PLAN.md
REFACTOR_PLAN.md
demo/
*.cast
*.gif

# Exception: README-embedded demo GIFs in docs/ ARE tracked
!docs/*.gif
custom_app-for-nyasha.tar.gz

# Local scratch / private notes (not for PRs)
.local/

build/

# v1.6: codegen chdir means offices write artifacts next to office.md,
# so gallery offices may write brief.html / *.jsonl into their own dir.
dissyslab/gallery/apps/*/brief.html
dissyslab/gallery/apps/*/snapshots/
dissyslab/gallery/apps/recovery_demo/samples/points.txt
